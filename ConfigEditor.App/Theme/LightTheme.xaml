<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Tokens -->
    <Color x:Key="ColorPrimary">#262682</Color>
    <Color x:Key="ColorPrimaryHover">#1F1F6A</Color>
    <Color x:Key="ColorPrimaryPressed">#171752</Color>
    <Color x:Key="ColorPrimarySoft">#EFEFFF</Color>
    <Color x:Key="ColorPrimaryLine">#DADAFA</Color>

    <Color x:Key="ColorAccent">#DA9274</Color>
    <Color x:Key="ColorAccentHover">#C97F63</Color>
    <Color x:Key="ColorAccentSoft">#FFF1EA</Color>
    <Color x:Key="ColorAccentSoftHover">#FFE5D8</Color>
    <Color x:Key="ColorAccentLine">#F0C3B2</Color>

    <Color x:Key="ColorAppBackground">#F7F7FB</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorBorder">#E3E3EE</Color>
    <Color x:Key="ColorBorderStrong">#CFCFE2</Color>

    <Color x:Key="ColorTextPrimary">#17172A</Color>
    <Color x:Key="ColorTextSecondary">#66667A</Color>
    <Color x:Key="ColorTextMuted">#9A9AAC</Color>
    <Color x:Key="ColorDisabled">#C2C2D2</Color>

    <Color x:Key="SuccessColor">#2F7D6D</Color>
    <Color x:Key="WarningColor">#DA9274</Color>
    <Color x:Key="ErrorColor">#C6535F</Color>
    <Color x:Key="ColorInputBackground">#FBFBFE</Color>
    <Color x:Key="ColorSelectionInactive">#F8F8FC</Color>

    <!-- Brush Resources -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource ColorPrimaryPressed}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush" Color="{StaticResource ColorPrimarySoft}"/>
    <SolidColorBrush x:Key="PrimaryLineBrush" Color="{StaticResource ColorPrimaryLine}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource ColorAccentHover}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource ColorAccentSoft}"/>
    <SolidColorBrush x:Key="AccentSoftHoverBrush" Color="{StaticResource ColorAccentSoftHover}"/>
    <SolidColorBrush x:Key="AccentLineBrush" Color="{StaticResource ColorAccentLine}"/>

    <LinearGradientBrush x:Key="IconGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorPrimary}" Offset="0"/>
        <GradientStop Color="#5757B8" Offset="0.48"/>
        <GradientStop Color="{StaticResource ColorAccent}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="IconGradientSoftBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorPrimarySoft}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentSoft}" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorAppBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource ColorBorderStrong}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource ColorDisabled}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource ColorInputBackground}"/>
    <SolidColorBrush x:Key="SelectionInactiveBgBrush" Color="{StaticResource ColorSelectionInactive}"/>

    <!-- Legacy aliases used by existing views. -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource ColorAppBackground}"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource ColorPrimarySoft}"/>
    <SolidColorBrush x:Key="HoverBorderBrush" Color="{StaticResource ColorPrimaryLine}"/>
    <SolidColorBrush x:Key="SelectionBgBrush" Color="{StaticResource ColorPrimarySoft}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="FgBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="FgMutedBrush" Color="{StaticResource ColorTextSecondary}"/>

</ResourceDictionary>

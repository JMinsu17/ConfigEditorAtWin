<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palettes -->
    <Color x:Key="BgColor">#FFFFFF</Color>
    <Color x:Key="PanelBgColor">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E1DDE8</Color>
    <Color x:Key="HoverBgColor">#F7F3F1</Color>
    <Color x:Key="HoverBorderColor">#DAB7A8</Color>
    <Color x:Key="InputBgColor">#FBFAFD</Color>
    <Color x:Key="SelectionBgColor">#F0EFF9</Color>
    <Color x:Key="SelectionInactiveBgColor">#F8F6FB</Color>
    
    <Color x:Key="AccentColor">#262682</Color>
    <Color x:Key="AccentHoverColor">#1B1B66</Color>
    <Color x:Key="SuccessColor">#2F7D6D</Color>
    <Color x:Key="WarningColor">#DA9274</Color>
    <Color x:Key="ErrorColor">#C6535F</Color>
    
    <Color x:Key="FgColor">#222238</Color>
    <Color x:Key="FgMutedColor">#6D6880</Color>

    <!-- Brush Resources -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource HoverBgColor}"/>
    <SolidColorBrush x:Key="HoverBorderBrush" Color="{StaticResource HoverBorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="SelectionBgBrush" Color="{StaticResource SelectionBgColor}"/>
    <SolidColorBrush x:Key="SelectionInactiveBgBrush" Color="{StaticResource SelectionInactiveBgColor}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}"/>
    <SolidColorBrush x:Key="FgMutedBrush" Color="{StaticResource FgMutedColor}"/>

</ResourceDictionary>

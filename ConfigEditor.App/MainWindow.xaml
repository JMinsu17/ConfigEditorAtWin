<Window x:Class="ConfigEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ConfigEditor.App.Views"
        xmlns:vm="clr-namespace:ConfigEditor.App.ViewModels"
        xmlns:conv="clr-namespace:ConfigEditor.App.Theme"
        mc:Ignorable="d"
        Title="ConfigEditor - JSON / INI"
        Width="1280"
        Height="900"
        MinWidth="1040"
        MinHeight="760"
        Background="{DynamicResource BgBrush}"
        FontFamily="{StaticResource MainFont}"
        Icon="icon/ConfigEditor.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SectionLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PaneBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="QuietIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RecentFileButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="TextOnlyButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DocumentListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="DocumentListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8,5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource HoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBgBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMutedBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SelectionBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ValidateActiveDocumentCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="True"
                   Background="{DynamicResource PanelBgBrush}"
                   SnapsToDevicePixels="True">
            <Menu DockPanel.Dock="Top"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="0,0,0,1"
                  Foreground="{DynamicResource FgBrush}"
                  Padding="8,3">
                <MenuItem Header="파일" Foreground="{DynamicResource FgBrush}">
                    <MenuItem Header="파일 열기..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                    <MenuItem Header="최근 파일" ItemsSource="{Binding RecentFilesList}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding}"/>
                                <EventSetter Event="Click" Handler="RecentFileMenuItem_Click"/>
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <Separator Background="{DynamicResource BorderBrush}"/>
                    <MenuItem Header="저장" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                    <MenuItem Header="다른 이름으로 저장..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S"/>
                    <MenuItem Header="현재 파일 닫기" Command="{Binding CloseFileCommand}" InputGestureText="Ctrl+W"/>
                    <Separator Background="{DynamicResource BorderBrush}"/>
                    <MenuItem Header="종료" Click="Exit_Click"/>
                </MenuItem>
                <MenuItem Header="편집 도구" Foreground="{DynamicResource FgBrush}">
                    <MenuItem Header="문서 검사" Command="{Binding ValidateActiveDocumentCommand}" InputGestureText="F5"/>
                    <MenuItem Header="수동 백업 만들기" Command="{Binding CreateBackupManualCommand}"/>
                    <MenuItem Header="백업 폴더 열기" Command="{Binding OpenBackupFolderCommand}"/>
                </MenuItem>
                <MenuItem Header="보기" Foreground="{DynamicResource FgBrush}">
                    <MenuItem Header="어두운 화면" Command="{Binding ChangeThemeCommand}" CommandParameter="Dark" IsCheckable="True" IsChecked="{Binding IsDarkTheme}"/>
                    <MenuItem Header="밝은 화면" Command="{Binding ChangeThemeCommand}" CommandParameter="Light" IsCheckable="True" IsChecked="{Binding IsLightTheme}"/>
                </MenuItem>
            </Menu>

            <Grid Margin="18,10,18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="icon/CE_64px.png"
                               Width="24"
                               Height="24"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Config Editor"
                                   Foreground="{DynamicResource FgBrush}"
                                   FontSize="18"
                                   FontWeight="ExtraBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="JSON / INI 설정 파일 편집"
                               Foreground="{DynamicResource FgMutedBrush}"
                               FontSize="12"
                               Margin="1,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="열기"
                            Command="{Binding OpenFileCommand}"
                            Style="{StaticResource PrimaryToolbarButtonStyle}"
                            ToolTip="JSON, INI, CFG 파일을 엽니다."/>
                    <Button Content="저장"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            ToolTip="현재 파일을 저장합니다."/>
                    <Button Content="다른 이름"
                            Command="{Binding SaveAsCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            ToolTip="현재 파일을 새 경로로 저장합니다."/>
                    <Button Content="검사"
                            Command="{Binding ValidateActiveDocumentCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="18,0,0,0"
                            ToolTip="현재 문서의 형식과 값을 검사합니다."/>
                    <Button Content="백업"
                            Command="{Binding CreateBackupManualCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            ToolTip="현재 파일의 백업을 만듭니다."/>
                    <Button Content="파일 조사"
                            Command="{Binding InspectFilesCommand}"
                            Style="{StaticResource PrimaryToolbarButtonStyle}"
                            Margin="8,0,0,0"
                            ToolTip="폴더를 선택해 열 수 있는 설정 파일을 모두 열린 파일에 추가합니다."/>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsInspectingFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar Width="72"
                                     Height="6"
                                     IsIndeterminate="True"
                                     VerticalAlignment="Center"
                                     Background="{DynamicResource InputBgBrush}"
                                     Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="조사 중"
                                   Foreground="{DynamicResource FgMutedBrush}"
                                   FontSize="11"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource StatusBadgeStyle}" Background="{DynamicResource SelectionBgBrush}">
                        <TextBlock Text="{Binding Documents.Count, StringFormat='열린 파일 {0}개'}"
                                   Foreground="{DynamicResource FgBrush}"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource StatusBadgeStyle}"
                            Background="{DynamicResource SelectionInactiveBgBrush}"
                            Margin="8,0,0,0"
                            Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="저장 안 됨"
                                   Foreground="{DynamicResource WarningBrush}"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </DockPanel>

        <Grid Grid.Row="1" Margin="18,0,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" MinWidth="300"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PaneBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="열린 파일"
                                       Style="{StaticResource SectionLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Documents.Count, StringFormat='{}{0}개'}"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontWeight="SemiBold"/>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <TextBlock Text="아직 열린 파일이 없습니다."
                                       Foreground="{DynamicResource FgMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding HasDocuments, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>

                            <ListBox ItemsSource="{Binding Documents}"
                                     SelectedItem="{Binding SelectedDocument}"
                                     Style="{StaticResource DocumentListBoxStyle}"
                                     ItemContainerStyle="{StaticResource DocumentListBoxItemStyle}"
                                     Visibility="{Binding HasDocuments, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ConfigDocumentViewModel}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="4"
                                                    CornerRadius="2"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Margin="0,2,8,2"/>

                                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{DynamicResource FgBrush}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FilePath}"/>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource SelectionInactiveBgBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="5,1"
                                                        Margin="6,0,0,0"
                                                        Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="수정됨"
                                                               Foreground="{DynamicResource WarningBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>

                                            <Button Grid.Column="2"
                                                    Content="×"
                                                    Command="{Binding DataContext.CloseFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource QuietIconButtonStyle}"
                                                    ToolTip="이 파일 닫기"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Button Grid.Row="2"
                                Content="파일 열기"
                                Command="{Binding OpenFileCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0"/>

                        <Border Grid.Row="3"
                                Background="{DynamicResource BorderBrush}"
                                Height="1"
                                Margin="0,12,0,10"
                                Visibility="{Binding HasRecentFiles, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <DockPanel Grid.Row="4"
                                   Margin="0,0,0,6"
                                   Visibility="{Binding HasRecentFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="최근 파일"
                                       Style="{StaticResource SectionLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding RecentFilesList.Count, StringFormat='{}{0}개'}"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource FgMutedBrush}"
                                       FontSize="11"/>
                        </DockPanel>

                        <ScrollViewer Grid.Row="5"
                                      MaxHeight="150"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasRecentFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding RecentFilesList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RecentFileButtonStyle}"
                                                ToolTip="{Binding}">
                                            <TextBlock Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="10"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2"
                    Style="{StaticResource PaneBorderStyle}"
                    Visibility="{Binding HasSelectedDocument, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                <Grid Margin="40">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="520">
                        <TextBlock Text="설정 파일을 열어 편집을 시작하세요"
                                   Foreground="{DynamicResource FgBrush}"
                                   FontSize="24"
                                   FontWeight="ExtraBold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="JSON, INI, CFG 파일을 열면 왼쪽에는 파일 목록과 구조가, 오른쪽에는 원문 편집기와 폼 편집기가 표시됩니다."
                                   Foreground="{DynamicResource FgMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,12,0,22"/>
                        <Button Content="파일 열기"
                                Command="{Binding OpenFileCommand}"
                                Style="{StaticResource PrimaryToolbarButtonStyle}"
                                HorizontalAlignment="Center"
                                MinWidth="140"
                                ToolTip="편집할 설정 파일을 선택합니다."/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2"
                  Visibility="{Binding HasSelectedDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10">
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="10"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationIssues}" Value="False">
                                        <Setter Property="Height" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                    <RowDefinition Height="150" MinHeight="100">
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="150"/>
                                <Setter Property="MinHeight" Value="100"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasValidationIssues}" Value="False">
                                        <Setter Property="Height" Value="0"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PaneBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Background="{DynamicResource PanelBgBrush}"
                              Margin="16,12,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding SelectedDocument.FileName}"
                                           Foreground="{DynamicResource FgBrush}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Grid.Column="1"
                                        Style="{StaticResource StatusBadgeStyle}"
                                        Background="{DynamicResource SelectionInactiveBgBrush}"
                                        Padding="8,3"
                                        Margin="10,0,0,0"
                                        Visibility="{Binding SelectedDocument.IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="수정됨"
                                               Foreground="{DynamicResource WarningBrush}"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding SelectedDocument.FilePath}"
                                           Foreground="{DynamicResource FgMutedBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding SelectedDocument.FilePath}"/>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Background="{DynamicResource SelectionBgBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="10,5"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedDocument.Format, StringFormat='형식: {0}'}"
                                               Foreground="{DynamicResource FgBrush}"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Button Content="폴더 열기"
                                        Command="{Binding OpenSelectedFileFolderCommand}"
                                        Style="{StaticResource TextOnlyButtonStyle}"
                                        Margin="8,0,0,0"
                                        ToolTip="선택한 파일이 있는 폴더를 엽니다."/>
                            </StackPanel>
                        </Grid>

                        <TabControl x:Name="MainTabControl"
                                    Grid.Row="1"
                                    SelectionChanged="MainTabControl_SelectionChanged"
                                    Background="{DynamicResource PanelBgBrush}"
                                    BorderThickness="0"
                                    Margin="1,12,1,1">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource EditorTabItemStyle}"/>
                            </TabControl.Resources>

                            <TabItem x:Name="RawTextTab" Header="원문 편집">
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,1,0,0">
                                    <views:RawTextEditorView/>
                                </Border>
                            </TabItem>
                            <TabItem x:Name="FormTab" Header="폼 편집">
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300" MinWidth="240"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*" MinWidth="320"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0"
                                              Background="{DynamicResource PanelBgBrush}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0" Margin="14,10,14,8">
                                                <TextBlock Text="문서 구조"
                                                           Style="{StaticResource SectionLabelTextStyle}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding SelectedDocument.Format, StringFormat='{}{0}', FallbackValue=''}"
                                                           DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource FgMutedBrush}"
                                                           FontSize="11"/>
                                            </DockPanel>
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource InputBgBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1,0,1,0"
                                                    Padding="2">
                                                <views:ConfigTreeView/>
                                            </Border>
                                        </Grid>

                                        <GridSplitter Grid.Column="1"
                                                      Width="10"
                                                      HorizontalAlignment="Stretch"
                                                      Background="Transparent"/>

                                        <views:ConfigFormEditorView Grid.Column="2"/>
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1"
                              Height="10"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Visibility="{Binding HasValidationIssues, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Border Grid.Row="2"
                        Style="{StaticResource PaneBorderStyle}"
                        Visibility="{Binding HasValidationIssues, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="14,10,14,8">
                            <TextBlock Text="검사 결과"
                                       Style="{StaticResource SectionLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ValidationResults.Count, StringFormat='{}{0}개 문제'}"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource WarningBrush}"
                                       FontWeight="SemiBold"/>
                        </DockPanel>
                        <views:ValidationPanelView Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2"
                   Background="{DynamicResource PanelBgBrush}"
                   Foreground="{DynamicResource FgMutedBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   Padding="8,4"
                   Margin="0,18,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedDocument.FilePath, FallbackValue='열린 파일 없음'}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="760"/>
            </StatusBarItem>
            <Separator Background="{DynamicResource BorderBrush}"/>
            <StatusBarItem>
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="검사 통과"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="문제가 없습니다" Foreground="{DynamicResource FgBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasValidationIssues}" Value="True">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="확인 필요"
                                                               Foreground="{DynamicResource WarningBrush}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding ValidationResults.Count, StringFormat='{}{0}개 문제 발견'}"
                                                               Foreground="{DynamicResource FgBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedDocument}" Value="{x:Null}">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="준비됨"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </StatusBarItem>
            <Separator Background="{DynamicResource BorderBrush}"/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedDocument.Format, StringFormat='형식: {0}', FallbackValue='형식: 없음'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
